# ── Vagrant / VirtualBox ─────────────────────────────────────────
# Trạng thái máy ảo, sinh ra khi `vagrant up`, không commit
.vagrant/
*.box
*.vdi
*.vmdk
ubuntu-*.log

# ── k3s secrets / kubeconfig ─────────────────────────────────────
# Token join cluster + kubeconfig chứa client cert — TUYỆT ĐỐI không push
*.kubeconfig
kubeconfig
k3s.yaml
node-token
*node-token*
*.token
fetched/

# ── Ansible ──────────────────────────────────────────────────────
*.retry
ansible/*.retry
# Bỏ comment nếu inventory chứa thông tin nhạy cảm:
# ansible/inventory.ini

